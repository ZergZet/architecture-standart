@startuml C4-Container-Deposits-MVP
title Открытие депозитов (MVP) Container Diagram
top to bottom direction

!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Component.puml
!includeurl https://raw.githubusercontent.com/RicardoNiepel/C4-PlantUML/master/C4_Container.puml

Person(Client, "Клиент банка")
Person_Ext(CallCenterEmployeeExternal, "Сотрудник партнёрского Кол-центра")

System_Ext(SMSGate, "SMS-шлюз")
System_Ext(Telecom, "Телеком оператор")
System_Ext(CallCenterSystemExternal, "Система партнёрского кол-центра")
    
Boundary(StandartSystem, "Банк Стандарт"){ 

    Person(CallCenterEmployee, "Сотрудник Кол-центра")
    Person(DepositeManager, "Менеджер депозитов бэк-офиса")
    Person(CreditManager, "Кредитный менеджер бэк-офиса")
    Person(FrontOficceManager, "Сотрудник фронт-офиса")
    
    System(WebSite, "Сайт банка", "[PHP, React.js]")
    System(CallCenterSystem, "Система кол-центра", "[React.js, Java Spring Boot, PostgreSQL]")
    
    Rel(CallCenterSystemExternal, CallCenterSystem, "Передача заявки на расчёт ставки депозита")
    Rel(CallCenterEmployee, CallCenterSystem, "Регистрация заявки на расчёт ставки депозита")
    Rel(CallCenterEmployeeExternal, CallCenterSystemExternal, "Регистрация заявки на расчёт ставки депозита")

    Boundary(Internal, ""){ 
        Container(SMSService, "Сервис оповещения клиентов банка", ".NET", "Реализует СМС оповещение")
        ContainerQueue(MessageQueue, "Очередь сообщений", "Message Queue", "Шина событий и заявок для асинхронной коммуникации")
    }

    Boundary(ABSSystem, "АБС"){ 
        Container(ABS, "АБС", "Delphi", "Фиксация заявок и условий депозитов")
        ContainerDb(ABSDB, "АБС Database", "Oracle", "Хранение данных по депозитам и клиентам")
        Rel(ABS, ABSDB, "Чтение / запись")
    }

    Boundary(InternetBankSystem, "Модифицированный Интернет Банк (MVP)"){ 
        Container(IBankUI, "Интернет-банк (Web UI)", "ASP.NET MVC 4.5", "Пользовательский интерфейс подачи заявок")
        Container(APIGW, "API-Gateway", ".NET", "Масштабирование, балансировка нагрузки, шифрование трафика, проксирование и аутентификация")
        
        Container(AuthService, "Authentication Service", ".NET", "Аутентификация и управление пользователями")
        ContainerDb(UserDB, "User Database", "MS SQL", "Хранит данные пользователей")
        Rel(APIGW, AuthService, "Идентификация и аутентификация пользователей", "https") 
        Rel(AuthService, UserDB, "Чтение/запись", "SQL") 
        Rel(AuthService, SMSGate, "Подтвержение входа по SMS", "") 
                
        Container(IBankBackEnd, "Интернет-банк", ".NET Framework", "Передаёт заявки в Backend депозитов")

        ContainerDb(IBankBackDB, "СУБД Интернет-банка", "MS SQL", "Хранит данные интернет банка")
        Rel(IBankBackEnd, IBankBackDB, "Чтение/запись", "MS SQL") 

        Container(DepositeService, "Сервис открытия допозитов (MVP)", ".NET", "Принимает заявки на депозит, отслеживает процесс согласования открытия депозитов")
    }
}

Rel(IBankUI, APIGW,  "Управление интернет банком","HTTPS")
Rel(APIGW, IBankBackEnd, "Управление интернет банком","HTTPS")
Rel(APIGW, DepositeService, "Управление заявками на депозит","HTTPS")

Rel(DepositeManager, ABS, "Взаимодействие с АБС")
Rel(ABS,DepositeManager,  "")
Rel(CreditManager, ABS, "Взаимодействие с АБС")
Rel(ABS,CreditManager,  "")
Rel(FrontOficceManager, ABS, "Взаимодействие с АБС")
Rel(ABS, FrontOficceManager, "")

Rel(Client, WebSite, "Регистируется, подаёт заявку на депозит")
Rel(WebSite, CallCenterSystem, "Регистирует заявку на депозит")
Rel(CallCenterSystem, APIGW, "Заявки на депозит")

Rel(Client, IBankUI, "Подаёт заявку")

Rel(DepositeService, MessageQueue, "Публикация сообщений")
Rel(MessageQueue, DepositeService, "Обработка пообщений")
Rel(MessageQueue, ABS, "Обработка заявок", "HTTPS") 
Rel(ABS, MessageQueue,  "", "HTTPS") 

Rel(MessageQueue, SMSService, "Событие оповещения")
Rel(SMSService, SMSGate, "Отправка SMS")
Rel(SMSGate, Telecom, "Отправка SMS")

@enduml
